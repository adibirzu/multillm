# Authoritative env-var inventory. CI test tests/test_env_example_coverage.py
# verifies every os.environ / os.getenv lookup in multillm/ has an entry here.
#
# Quickstart: cp .env.example .env && docker compose up
#
# SECURITY: Never commit your actual .env. It's in .gitignore. All secret
# placeholders below are intentionally empty — gitleaks must NOT flag this file.

# ── Gateway core ───────────────────────────────────────────────────────────
# Bind host for the FastAPI server inside the container.
# type: str, default: 127.0.0.1
GATEWAY_HOST=0.0.0.0

# TCP port the gateway listens on.
# type: int, default: 8080
GATEWAY_PORT=8080

# Enable uvicorn --reload (development only; never set in production).
# type: bool (true|false), default: false
GATEWAY_RELOAD=false

# Comma-separated CORS origins; empty disables CORS middleware.
# type: str (CSV), default: ""
GATEWAY_CORS_ORIGINS=

# Logging output format. "text" = human-readable; "json" = structured logs.
# type: enum (text|json), default: text
LOG_FORMAT=text

# ── Storage ────────────────────────────────────────────────────────────────
# Override the data directory (SQLite DBs, backups, PID file, logs).
# In Docker the compose file maps host ${MULTILLM_HOME:-./.multillm} -> /data.
# type: path, default: ~/.multillm
MULTILLM_HOME=

# Alternative knob for the data directory (legacy alias of MULTILLM_HOME).
# When both are set, MULTILLM_DATA_DIR wins.
# type: path, default: (falls back to MULTILLM_HOME, then ~/.multillm)
MULTILLM_DATA_DIR=

# Absolute path to the tracking SQLite DB. Overrides default of
# $MULTILLM_HOME/multillm.db. Use only if you need a non-standard DB location.
# type: path, default: (computed from MULTILLM_HOME)
MULTILLM_DB_PATH=

# Project tag attached to every tracked request (for per-project usage rollup).
# Auto-detected from the cwd basename if unset.
# type: str, default: (cwd basename)
MULTILLM_PROJECT=

# ── Auth (gateway-wide, optional) ──────────────────────────────────────────
# If set, every /v1/* call must present X-Api-Key: $MULTILLM_API_KEY.
# Empty disables gateway-wide auth (Phase 2b replaces this with per-tenant keys).
# type: str (secret), default: ""
MULTILLM_API_KEY=

# Expose /api/dashboard and /api/sessions read-only without auth.
# type: bool (true|false), default: false
MULTILLM_PUBLIC_DASHBOARD_API=false

# Isolate memory per tenant in the MCP server: when on, the per-user MCP server
# tags writes with the UNIX user and filters reads to it. Off keeps memory globally
# shared (single-user / standalone). The HTTP X-MultiLLM-Tenant header always works
# regardless of this flag.
# type: bool (true|false), default: false
MULTILLM_ENFORCE_TENANT=false

# Allow non-loopback clients to reach the gateway when MULTILLM_API_KEY is unset.
# Set true ONLY if you understand the implications (no auth on /v1/messages).
# type: bool (true|false), default: false
MULTILLM_ALLOW_UNAUTHENTICATED_REMOTE=false

# ── Team usage monitoring (multi-user / multi-account) ───────────────────────
# Aggregates per-developer, per-account LLM usage on shared dev workstations.
# The gateway exposes /api/usage/ingest, /api/team-usage and /team; a per-user
# collector (multillm.team_collector) reads each developer's local CLI stats
# and pushes daily snapshots. See devvm/oci-remote-dev for the deployment glue.

# Per-user daily cost caps surfaced as an `over_budget` flag on /api/team-usage.
# Format: "user=usd,user=usd" (e.g. adi=5,royce=10). type: str, default: ""
MULTILLM_USER_BUDGETS=

# ---- Collector-side (set in the collector's environment, per workstation) ----
# Gateway base URL the collector POSTs snapshots to.
# type: url, default: http://localhost:8080
MULTILLM_GATEWAY=

# Tenant label for collected usage (defaults to $USER if unset).
# type: str, default: "" (falls back to $USER / getpass.getuser())
MULTILLM_TENANT=

# Workstation hostname recorded with each snapshot.
# type: str, default: socket.gethostname()
MULTILLM_HOST=

# Lookback window the collector reports each run, in hours.
# type: int, default: 168
MULTILLM_COLLECT_HOURS=

# Override auto-detected provider account labels per backend.
# Format: "backend=account,backend=account" (e.g. claude=me@x.com,codex=team).
# type: str, default: ""
MULTILLM_ACCOUNTS=

# ── Observability ──────────────────────────────────────────────────────────
# Enable OpenTelemetry trace + metric export.
# type: bool (true|false), default: false
OTEL_ENABLED=false

# OTel service.name attribute attached to every span.
# type: str, default: multillm-gateway
OTEL_SERVICE_NAME=multillm-gateway

# OCI APM destination (set all three to export traces/metrics to OCI APM).
# Use the literal placeholder strings below — gitleaks treats them as safe.
# type: str (OCID), default: ""
OCI_APM_DOMAIN_ID=

# type: str (data-key, secret), default: ""
OCI_APM_DATA_KEY=your-oci-apm-data-key-here

# type: str (region), default: eu-frankfurt-1
OCI_APM_REGION=

# OCI APM full OTLP endpoint URL. Leave unset to derive automatically from
# OCI_APM_REGION + OCI_APM_DOMAIN_ID. Override only if you need a custom path.
# type: url, default: (derived)
OCI_APM_ENDPOINT=

# Scoring weights for the health-aware router (Phase 4 will tune defaults).
# type: float in [0,1], default: 0.45
SCORE_HEALTH_WEIGHT=

# type: float in [0,1], default: 0.35
SCORE_LATENCY_WEIGHT=

# type: float in [0,1], default: 0.20
SCORE_ERROR_WEIGHT=

# Sampling rate for OpenTelemetry traces; forward-reference for Phase 5
# (multillm/ does not read it directly today but the operator may set it).
# type: float in [0,1], default: 1.0
OTEL_TRACES_SAMPLER_ARG=

# ── Rate limiting (disabled by default) ───────────────────────────────────
# Requests-per-minute per client (API key or IP). 0 disables the limit.
# type: int, default: 0
RATE_LIMIT_RPM=0

# Maximum concurrent in-flight requests per client. 0 disables the cap.
# type: int, default: 0
RATE_LIMIT_CONCURRENT=0

# ── Local backends (free, no API key) ─────────────────────────────────────
# Ollama HTTP base URL.
# type: url, default: http://localhost:11434
OLLAMA_URL=http://localhost:11434

# LM Studio HTTP base URL.
# type: url, default: http://localhost:1234
LMSTUDIO_URL=http://localhost:1234

# Codex CLI default profile name (matches a profile in ~/.codex/config.toml).
# type: str, default: gpt-5-4
CODEX_DEFAULT_PROFILE=

# Codex CLI fallback model name reported back to callers when no profile model
# can be resolved.
# type: str, default: gpt-5.4
CODEX_DEFAULT_MODEL=

# Codex CLI sandbox mode override.
# type: enum (read-only|workspace-write|danger-full-access), default: read-only
CODEX_SANDBOX=read-only

# Gemini CLI default model.
# type: str, default: gemini-2.5-flash
GEMINI_CLI_DEFAULT_MODEL=

# Gemini CLI approval mode for tool calls.
# type: enum (yolo|default|auto_edit|plan), default: yolo
GEMINI_APPROVAL_MODE=yolo

# ── Cloud backend API keys (all empty by default) ─────────────────────────
# OpenAI direct API key.
# type: str (secret), default: ""
OPENAI_API_KEY=

# Anthropic direct API key. Named *_REAL_KEY to disambiguate from Claude Code's
# session-bound credential.
# type: str (secret), default: ""
ANTHROPIC_REAL_KEY=

# Google Gemini API key.
# type: str (secret), default: ""
GEMINI_API_KEY=

# Google Cloud generic API key; used as a fallback when GEMINI_API_KEY is empty.
# type: str (secret), default: ""
GOOGLE_API_KEY=

# OpenRouter API key.
# type: str (secret), default: ""
OPENROUTER_API_KEY=

# Groq API key.
# type: str (secret), default: ""
GROQ_API_KEY=

# DeepSeek API key.
# type: str (secret), default: ""
DEEPSEEK_API_KEY=

# Mistral API key.
# type: str (secret), default: ""
MISTRAL_API_KEY=

# Together AI API key.
# type: str (secret), default: ""
TOGETHER_API_KEY=

# xAI (Grok) API key.
# type: str (secret), default: ""
XAI_API_KEY=

# Fireworks AI API key.
# type: str (secret), default: ""
FIREWORKS_API_KEY=

# ── Cloud backend configuration ───────────────────────────────────────────
# Azure OpenAI API key.
# type: str (secret), default: ""
AZURE_OPENAI_API_KEY=

# Azure OpenAI resource endpoint, e.g. https://myresource.openai.azure.com
# type: url, default: ""
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI API version pin.
# type: str (date), default: 2024-10-21
AZURE_OPENAI_API_VERSION=2024-10-21

# AWS Bedrock region; falls back to AWS_DEFAULT_REGION.
# type: str (region), default: us-east-1
AWS_BEDROCK_REGION=us-east-1

# Standard AWS region env var; read as a fallback for AWS_BEDROCK_REGION.
# type: str (region), default: ""
AWS_DEFAULT_REGION=

# Named AWS credentials profile (~/.aws/credentials) for Bedrock.
# type: str, default: ""
AWS_BEDROCK_PROFILE=

# ── Oracle Code Assist (OCA) ──────────────────────────────────────────────
# OCA API endpoint URL.
# type: url, default: ""
OCA_ENDPOINT=

# OCA API version pin.
# type: str (date), default: 20250206
OCA_API_VERSION=20250206

# OAuth PKCE callback port for `multillm-oca-login`.
# type: int, default: 48801
OCA_CALLBACK_PORT=48801

# Directory for the cached OCA OAuth token.
# type: path, default: ~/.oca
OCA_CACHE_DIR=

# OCA IDCS (Oracle Identity Cloud Service) base URL.
# Aliases also read by config.py: OCA_IDCS_OAUTH_URL, OCI_IDCS_OAUTH_URL,
# IDCS_URL, ORACLE_SSO_OAUTH_URL.
# type: url, default: ""
OCA_IDCS_URL=
OCA_IDCS_OAUTH_URL=
OCI_IDCS_OAUTH_URL=
IDCS_URL=
ORACLE_SSO_OAUTH_URL=

# OCA OAuth client ID.
# Aliases also read by config.py: OCA_IDCS_CLIENT_ID, OCI_IDCS_CLIENT_ID,
# IDCS_CLIENT_ID, ORACLE_SSO_CLIENT_ID.
# type: str, default: ""
OCA_CLIENT_ID=
OCA_IDCS_CLIENT_ID=
OCI_IDCS_CLIENT_ID=
IDCS_CLIENT_ID=
ORACLE_SSO_CLIENT_ID=

# ── Router config ─────────────────────────────────────────────────────────
# Path to a JSON file that overrides DEFAULT_ROUTES at startup.
# type: path, default: ""
ROUTER_CONFIG_PATH=

# Base URL used by client/skill code to find the gateway.
# type: url, default: http://localhost:8080
LLM_GATEWAY_URL=http://localhost:8080

# ── Integration toggles ───────────────────────────────────────────────────
# Langfuse — LLM observability platform.
# type: bool (true|false), default: false
LANGFUSE_ENABLED=false

# type: str (public key), default: ""
LANGFUSE_PUBLIC_KEY=

# type: str (secret), default: ""
LANGFUSE_SECRET_KEY=

# type: url, default: http://localhost:3001
LANGFUSE_HOST=http://localhost:3001

# Redis LangCache — semantic caching layer (Phase 6 ships sqlite-vec; this is
# the legacy hook).
# type: bool (true|false), default: false
LANGCACHE_ENABLED=false

# type: str, default: ""
LANGCACHE_HOST=

# type: str, default: ""
LANGCACHE_CACHE_ID=

# type: str (secret), default: ""
LANGCACHE_API_KEY=

# Cosine-similarity threshold above which a cached entry is reused.
# type: float in [0,1], default: 0.92
LANGCACHE_THRESHOLD=0.92

# Allow cross-model cache hits (a hit on model A served to a call for model B).
# type: bool (true|false), default: false
LANGCACHE_CROSS_MODEL=false
