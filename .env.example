# ── MultiLLM Gateway Configuration ─────────────────────────────────────────
# Copy to .env and fill in values for your setup.
# Only set what you have — the gateway works with any subset of backends.
#
# SECURITY: Never commit your actual .env file. It's in .gitignore.

# ── Gateway ────────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
# MULTILLM_API_KEY=            # Set to require API key auth on all /v1/* endpoints
# MULTILLM_DATA_DIR=~/.multillm
# MULTILLM_PROJECT=default     # Auto-detected from cwd if not set

# ── Local Backends (free, no API key needed) ───────────────────────────────
OLLAMA_URL=http://localhost:11434
LMSTUDIO_URL=http://localhost:1234

# ── OpenAI ─────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Anthropic (direct API, not via Claude Code) ───────────────────────────
# ANTHROPIC_REAL_KEY=sk-ant-...

# ── Google Gemini ──────────────────────────────────────────────────────────
# GEMINI_API_KEY=...
# Or: GOOGLE_API_KEY=...

# ── OpenRouter (multi-model cloud) ────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-...

# ── Groq (ultra-fast inference) ───────────────────────────────────────────
# GROQ_API_KEY=gsk_...

# ── DeepSeek (reasoning + code) ──────────────────────────────────────────
# DEEPSEEK_API_KEY=sk-...

# ── Mistral ───────────────────────────────────────────────────────────────
# MISTRAL_API_KEY=...

# ── Together AI ───────────────────────────────────────────────────────────
# TOGETHER_API_KEY=...

# ── xAI (Grok) ───────────────────────────────────────────────────────────
# XAI_API_KEY=xai-...

# ── Fireworks AI ──────────────────────────────────────────────────────────
# FIREWORKS_API_KEY=...

# ── Azure OpenAI ──────────────────────────────────────────────────────────
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://myresource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-10-21

# ── AWS Bedrock ───────────────────────────────────────────────────────────
# Uses standard AWS credentials (~/.aws/credentials or IAM roles)
# AWS_BEDROCK_REGION=us-east-1
# AWS_BEDROCK_PROFILE=default    # Optional: named AWS profile

# ── Oracle Code Assist (OCA) ─────────────────────────────────────────────
# OCA_ENDPOINT=https://...       # Your OCA endpoint URL
# OCA_API_VERSION=20250206
# OCA_IDCS_URL=https://...       # IDCS identity URL
# OCA_CLIENT_ID=...              # OAuth client ID

# ── OpenTelemetry / OCI APM (optional observability) ─────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=multillm-gateway
# Standard OTLP endpoint (if not using OCI APM):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://...
#
# OCI APM destination (set all three to export to OCI APM):
# OCI_APM_DOMAIN_ID=ocid1.apmdomain.oc1...
# OCI_APM_DATA_KEY=<your-public-data-key>
# OCI_APM_REGION=eu-frankfurt-1

# ── Semantic Cache (optional, requires Redis) ────────────────────────────
# LANGCACHE_ENABLED=true
# LANGCACHE_HOST=localhost
# LANGCACHE_CACHE_ID=multillm
# LANGCACHE_API_KEY=...
